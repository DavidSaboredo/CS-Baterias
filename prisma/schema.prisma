generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id           Int      @id @default(autoincrement())
  name         String
  phone        String?
  licensePlate String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sales        Sale[]
  appointments Appointment[]
}

model Appointment {
  id          Int      @id @default(autoincrement())
  startTime   DateTime
  endTime     DateTime
  clientId    Int
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  reason      String   // 'Batería', 'Audio', 'Revisión', etc.
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Sale {
  id               Int      @id @default(autoincrement())
  date             DateTime @default(now())
  clientId         Int
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  productId        Int
  product          Product  @relation(fields: [productId], references: [id])
  serialNumber     String
  price            Float
  originalPrice    Float?   // Precio de lista al momento de la venta
  discount         Float?   // Monto descontado
  warrantyDuration Int      // Duration in months
  status           String   @default("active") // active, expired, returned
}

model Product {
  id        Int      @id @default(autoincrement())
  brand     String
  model     String
  amperage  String
  imageUrl  String?
  codigoAleatorio String @unique @db.Char(3) @map("codigo_aleatorio")
  stock     Int      @default(0)
  minStock  Int      @default(5)
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sales     Sale[]
  competitorPrices CompetitorPrice[]
}

model ScraperSource {
  id                    Int      @id @default(autoincrement())
  name                  String
  url                   String
  priceSelector         String
  availabilitySelector  String?
  active                Boolean  @default(true)
  lastFetchedAt         DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  competitorPrices      CompetitorPrice[]
}

model CompetitorPrice {
  id            Int      @id @default(autoincrement())
  productId     Int
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sourceId      Int
  source        ScraperSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  price         Float
  availability  Boolean?
  fetchedAt     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
  @@index([sourceId])
  @@index([fetchedAt])
}
