generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

model Client {
  id           Int      @id @default(autoincrement())
  name         String
  phone        String?
  licensePlate String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sales        Sale[]
  appointments Appointment[]
}

model Appointment {
  id          Int      @id @default(autoincrement())
  startTime   DateTime
  endTime     DateTime
  clientId    Int
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  reason      String   // 'Batería', 'Audio', 'Revisión', etc.
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Sale {
  id               Int      @id @default(autoincrement())
  date             DateTime @default(now())
  clientId         Int
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  productId        Int
  product          Product  @relation(fields: [productId], references: [id])
  serialNumber     String
  price            Float
  originalPrice    Float?   // Precio de lista al momento de la venta
  discount         Float?   // Monto descontado
  warrantyDuration Int      // Duration in months
  status           String   @default("active") // active, expired, returned
}

model Product {
  id        Int      @id @default(autoincrement())
  brand     String
  model     String
  amperage  String
  stock     Int      @default(0)
  minStock  Int      @default(5)
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sales     Sale[]
}
